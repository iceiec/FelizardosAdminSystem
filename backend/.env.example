# Backend Environment Variables Template
# Copy this to backend/.env and fill in your values

# PostgreSQL Connection (Supabase)
DATABASE_URL=postgresql://postgres:PASSWORD@db.xxx.supabase.co:5432/postgres
DB_HOST=db.xxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=YOUR_SUPABASE_PASSWORD

# JWT Authentication
JWT_SECRET=your-generated-secret-key-here

# Server Configuration
NODE_ENV=development
PORT=5000

# CORS - Frontend URL (for production)
# Leave empty for development, set to Vercel URL for production
FRONTEND_URL=https://your-frontend.vercel.app

# For production (Render/Railway):
# NODE_ENV=production
# DATABASE_URL should point to your Supabase instance
# FRONTEND_URL should point to your Vercel deployment
